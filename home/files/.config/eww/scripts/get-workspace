#!/bin/sh
# Push the motto for a StumpWM group to eww's workspace-motto variable.
# Usage: get-workspace [GROUP]; queries StumpWM via stumpish when omitted.

group=${1:-$(echo '(group-name (current-group))' | stumpish -e eval | tr -d '"')}

case "$group" in
	" I ")
		motto="「　思想を閉ざす事勿れ
変化を恐るる事勿れ　」" ;;
	" II ")
		motto="「　望む真に非ず
真実を常求めよ　」" ;;
	" III ")
		motto="「　科学をもって
自然の理を理解せよ　」" ;;
	*)
		motto="「　人生一本道に非ず　」" ;;
esac

# EWW_CONFIG lets a preview daemon (eww --config DIR) be targeted too.
exec eww ${EWW_CONFIG:+--config "$EWW_CONFIG"} update workspace-motto="$motto"
